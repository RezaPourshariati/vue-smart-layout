{
  "name": "@adaptive-auth/auth-server",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:tokens": "tsx scripts/migrate-legacy-tokens.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cryptr": "^6.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "nodemailer": "^8.0.6",
    "nodemailer-express-handlebars": "^7.0.0",
    "rate-limiter-flexible": "^11.1.0",
    "ua-parser-js": "^2.0.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.1",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^7.2.0",
    "@types/ua-parser-js": "^0.7.39",
    "mongodb-memory-server": "^11.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
