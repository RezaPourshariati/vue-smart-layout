{
  "name": "adaptive-auth",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --dir apps/vue-app dev",
    "dev:vue-app": "pnpm --dir apps/vue-app dev",
    "dev:auth-server": "pnpm --dir services/auth-server dev",
    "dev:full": "run-p dev:vue-app dev:auth-server",
    "dev:front-end": "pnpm dev:vue-app",
    "dev:back-end": "pnpm dev:auth-server",
    "preview": "pnpm --dir apps/vue-app preview",
    "build:vue-app": "pnpm --dir apps/vue-app build",
    "build:auth-server": "pnpm --dir services/auth-server build",
    "build:front-end": "pnpm build:vue-app",
    "build:back-end": "pnpm build:auth-server",
    "build": "run-p type-check build:vue-app build:auth-server",
    "type-check:vue-app": "pnpm --dir apps/vue-app type-check",
    "type-check:auth-server": "pnpm --dir services/auth-server type-check",
    "type-check:front-end": "pnpm type-check:vue-app",
    "type-check:back-end": "pnpm type-check:auth-server",
    "type-check": "run-p type-check:vue-app type-check:auth-server",
    "test:auth-server": "pnpm --dir services/auth-server test",
    "test:vue-app": "pnpm --dir apps/vue-app test",
    "test:back-end": "pnpm test:auth-server",
    "test:front-end": "pnpm test:vue-app",
    "test:e2e": "pnpm --dir apps/vue-app test:e2e",
    "lint": "run-p lint:vue-app lint:auth-server",
    "lint:vue-app": "eslint \"./apps/vue-app/src/**/*.{ts,vue}\" \"./apps/vue-app/tests/**/*.ts\"",
    "lint:auth-server": "eslint ./services/auth-server/src ./services/auth-server/tests",
    "lint:front-end": "pnpm lint:vue-app",
    "lint:back-end": "pnpm lint:auth-server",
    "lint:fix": "run-p lint:fix:vue-app lint:fix:auth-server",
    "lint:fix:vue-app": "eslint \"./apps/vue-app/src/**/*.{ts,vue}\" \"./apps/vue-app/tests/**/*.ts\" --fix",
    "lint:fix:auth-server": "eslint ./services/auth-server/src ./services/auth-server/tests --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/node": "^25.6.2",
    "@unocss/eslint-plugin": "^66.6.8",
    "eslint": "^10.3.0",
    "eslint-plugin-format": "^2.0.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "^6.0.3"
  }
}
