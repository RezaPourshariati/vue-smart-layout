{
  "name": "adaptive-auth",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --dir apps/vue-app dev",
    "dev:vue-app": "pnpm --dir apps/vue-app dev",
    "dev:auth-server": "pnpm --dir services/auth-server dev",
    "dev:full": "run-p dev:vue-app dev:auth-server",
    "preview": "pnpm --dir apps/vue-app preview",
    "build:packages": "pnpm --filter @adaptive-auth/shared-types build && pnpm --filter @adaptive-auth/shared-auth build",
    "build:vue-app": "pnpm build:packages && pnpm --dir apps/vue-app build",
    "build:auth-server": "pnpm build:packages && pnpm --dir services/auth-server build",
    "build": "pnpm build:packages && run-p type-check build:vue-app build:auth-server",
    "type-check": "run-p type-check:vue-app type-check:auth-server",
    "type-check:vue-app": "pnpm build:packages && pnpm --dir apps/vue-app type-check",
    "type-check:auth-server": "pnpm build:packages && pnpm --dir services/auth-server type-check",
    "test": "run-p test:vue-app test:auth-server",
    "test:vue-app": "pnpm --dir apps/vue-app test",
    "test:auth-server": "pnpm --dir services/auth-server test",
    "test:shared-auth": "pnpm --dir packages/shared-auth test",
    "test:e2e": "pnpm --dir apps/vue-app test:e2e",
    "lint": "run-p lint:vue-app lint:auth-server",
    "lint:vue-app": "pnpm --dir apps/vue-app lint",
    "lint:auth-server": "pnpm --dir services/auth-server lint",
    "lint:fix": "run-p lint:fix:vue-app lint:fix:auth-server",
    "lint:fix:vue-app": "pnpm --dir apps/vue-app lint:fix",
    "lint:fix:auth-server": "pnpm --dir services/auth-server lint:fix"
  },
  "devDependencies": {
    "@adaptive-auth/eslint-config": "workspace:*",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "npm-run-all2": "^8.0.4",
    "typescript": "^6.0.3"
  }
}
