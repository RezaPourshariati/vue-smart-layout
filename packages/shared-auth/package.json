{
  "name": "@adaptive-auth/shared-auth",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic auth HTTP client for AdaptiveAuth frontends",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@adaptive-auth/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@adaptive-auth/config-typescript": "workspace:*",
    "happy-dom": "^20.9.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
