{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["./base.json", "@vue/tsconfig/tsconfig.dom.json"],
  "compilerOptions": {
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true,
    "preserveConstEnums": true
  }
}
