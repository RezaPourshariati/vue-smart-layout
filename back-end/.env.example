MONGO_URI=mongodb://localhost:27017/adaptive-auth

# Optional: shared rate-limit store for multi-instance deployments (e.g. redis://127.0.0.1:6379)
REDIS_URL=

# JSON auth telemetry lines to stdout (defaults on unless NODE_ENV=test). Override with true/false.
LOG_AUTH_TELEMETRY=

NODE_ENV=developmentPORT=4000
JWT_SECRET=replace-with-strong-jwt-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
# Refresh JWT cookie lifetime and DB rolling expiry window (default: 172800000 = 2 days)
REFRESH_TOKEN_LIFETIME_MS=172800000
# Maximum idle time before forcing login (default: 1800000 = 30 minutes)
SESSION_IDLE_TIMEOUT_MS=1800000
# Throttles DB writes for activity tracking; set <= SESSION_IDLE_TIMEOUT_MS (default: 30000 = 30s)
SESSION_LAST_USED_TOUCH_INTERVAL_MS=30000
# Absolute max session age regardless of activity (default: 2592000000 = 30 days)
SESSION_ABSOLUTE_TIMEOUT_MS=2592000000

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# development: when true, /sendLoginCode skips SMTP and only logs the code (see server console). Still logs the code when false.
DEV_LOGIN_CODE_CONSOLE_ONLY=false

FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

CRYPTR_KEY=replace-with-32-char-cryptr-key
GOOGLE_CLIENT_ID=replace-with-google-client-id
