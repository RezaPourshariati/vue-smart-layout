MONGO_URI=mongodb://localhost:27017/smart-layout-auth

NODE_ENV=development
PORT=4000
JWT_SECRET=replace-with-strong-jwt-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# development: when true, /sendLoginCode skips SMTP and only logs the code (see server console). Still logs the code when false.
DEV_LOGIN_CODE_CONSOLE_ONLY=false

FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

CRYPTR_KEY=replace-with-32-char-cryptr-key
GOOGLE_CLIENT_ID=replace-with-google-client-id
